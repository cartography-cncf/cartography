# scripts/: ignore everything (real env files hold secrets), but track *.example.yml templates.
# (Negation works because the dir itself is not excluded — only its contents via /*)
scripts/*
!scripts/*.example.yml
# config/: ignore real config (holds infra identifiers), track *.example.json templates.
config/*
!config/*.example.json

